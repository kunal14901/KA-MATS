# KA-MATS Cryptoz — Environment Variables
# Copy this file to .env and fill in your values

# ─── Execution Mode ──────────────────────────────────────────
#   paper                   = local simulation (no exchange, best for backtesting)
#   binance_testnet         = Binance spot testnet (fake money, real API)
#   binance_live            = Binance spot REAL MONEY
#   bybit_testnet           = Bybit spot testnet (fake money, real API)
#   bybit_live              = Bybit spot REAL MONEY
#   binance_futures_testnet = Binance USDT-M perpetuals testnet — SHORTS enabled
#   binance_futures_live    = Binance USDT-M perpetuals REAL MONEY — SHORTS enabled
#   bybit_futures_testnet   = Bybit perpetuals testnet — SHORTS enabled
#   bybit_futures_live      = Bybit perpetuals REAL MONEY — SHORTS enabled
# Futures modes run at 1x leverage (same exposure as spot, but shorts work).
EXECUTION_MODE=paper

# ─── Real-Time Data (optional) ───────────────────────────────
# 1 = push-based WebSocket OHLCV via ccxt.pro (~5ms) instead of REST polling
# USE_WEBSOCKET_DATA=1

# ─── Exchange API Keys ───────────────────────────────────────
# For Binance testnet: https://testnet.binance.vision (free, no real money)
# For Binance live:    https://www.binance.com/en/my/settings/api-management
# For Bybit testnet:   https://testnet.bybit.com
# For Bybit live:      https://www.bybit.com/app/user/api-management
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here

# ─── Safety Gate (required for live modes) ───────────────────
# Set to YES_I_WANT_REAL_MONEY to enable binance_live or bybit_live
# This prevents accidental live trading
# CONFIRM_LIVE=YES_I_WANT_REAL_MONEY

# ─── State Recovery ──────────────────────────────────────────
# Restore open positions and trade history from last session
# Set to 1 to resume, 0 to start fresh
EXECUTION_RECOVER_STATE=1

# ─── Risk Ramp-Up ────────────────────────────────────────────
# Scale risk gradually: 18% for first 50 trades, then full 27%
# Set to 0 to disable (use full risk immediately — paper/backtest only)
RISK_RAMP_ENABLED=1
